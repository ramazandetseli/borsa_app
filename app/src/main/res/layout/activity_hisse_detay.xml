<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/backHisseDetay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#1565C0"
        android:elevation="6dp"
        app:title="Hisse Detay"
        app:titleCentered="true"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/baseline_arrow_back_24"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/backHisseDetay"
        app:layout_constraintBottom_toTopOf="@id/bottomLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">


            <WebView
                android:id="@+id/tradingView"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                tools:ignore="WebViewLayout" />
            <!-- 🔹 2x2 Fiyat Alanı -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!-- SOL BLOK -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:text="Günlük Min"
                        android:textStyle="bold"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:id="@+id/tvMin"
                        android:text="-"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:layout_marginTop="12dp"
                        android:text="Günlük Max"
                        android:textStyle="bold"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:id="@+id/tvMax"
                        android:text="-"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>
                </LinearLayout>

                <!-- SAĞ BLOK -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:text="Güncel Fiyat"
                        android:textStyle="bold"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:id="@+id/tvValue"
                        android:text="-"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:layout_marginTop="12dp"
                        android:text="Ort. Maliyet"
                        android:textStyle="bold"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:id="@+id/tvMaliyet"
                        android:text="-"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Hacim:"
                    android:textStyle="bold"
                    android:layout_height="40dp"/>

                <TextView
                    android:id="@+id/tvVolume"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="-"
                    android:layout_height="40dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Lot:"
                    android:textStyle="bold"
                    android:layout_height="40dp"/>

                <TextView
                    android:id="@+id/tvLot"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="-"
                    android:layout_height="40dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvKarZarar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Getiri: -"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"/>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSell"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="SAT"
            android:textStyle="bold"
            android:backgroundTint="#E53935"
            app:cornerRadius="18dp"/>

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnBuy"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="AL"
            android:textStyle="bold"
            android:backgroundTint="#2E7D32"
            app:cornerRadius="18dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>