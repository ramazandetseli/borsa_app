<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="ara.hisseDetay">

    <!-- 🔝 TOOLBAR -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/backHisseDetay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:background="?attr/colorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:navigationIcon="@drawable/baseline_arrow_back_24"
        app:titleTextColor="@android:color/white"
        app:title="Geri Dön"
        android:backgroundTint="#1E88E5"/>



    <!-- 📜 SCROLLABLE CONTENT -->
    <ScrollView
        android:id="@+id/scrollView2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/backHisseDetay"
        app:layout_constraintBottom_toTopOf="@id/bottomLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">


            <WebView
                android:id="@+id/tradingView"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                tools:ignore="WebViewLayout" />
            <!-- 🔹 2x2 Fiyat Alanı -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!-- SOL BLOK -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:text="Günlük Min"
                        android:textStyle="bold"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:id="@+id/tvMin"
                        android:text="-"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:layout_marginTop="12dp"
                        android:text="Günlük Max"
                        android:textStyle="bold"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:id="@+id/tvMax"
                        android:text="-"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>
                </LinearLayout>

                <!-- SAĞ BLOK -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:text="Güncel Fiyat"
                        android:textStyle="bold"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:id="@+id/tvValue"
                        android:text="-"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:layout_marginTop="12dp"
                        android:text="Ort. Maliyet"
                        android:textStyle="bold"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:id="@+id/tvMaliyet"
                        android:text="-"
                        android:layout_width="60dp"
                        android:layout_height="40dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Hacim:"
                    android:textStyle="bold"
                    android:layout_height="40dp"/>

                <TextView
                    android:id="@+id/tvVolume"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="-"
                    android:layout_height="40dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Lot:"
                    android:textStyle="bold"
                    android:layout_height="40dp"/>

                <TextView
                    android:id="@+id/tvLot"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="-"
                    android:layout_height="40dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvKarZarar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Getiri: -"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"/>

        </LinearLayout>


    </ScrollView>
    <!-- ⬇️ ALT SABİT BAR -->
    <LinearLayout
        android:id="@+id/bottomLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >
        <Button
            android:id="@+id/btnSell"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="SATIŞ"
            android:backgroundTint="#E53935"/>
        <Button
            android:id="@+id/btnBuy"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="ALIŞ"
            android:backgroundTint="#1E88E5"
            />


    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>