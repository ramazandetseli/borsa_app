<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- 🔝 TOOLBAR -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/back_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#1565C0"
        android:elevation="8dp"
        app:title="Profil"

        app:titleCentered="true"
        app:titleTextColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 👤 PROFİL KART -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/profileCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/back_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <ImageView
                android:id="@+id/profile_image"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/ic_profile"
                android:padding="20dp"/>

            <TextView
                android:id="@+id/profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kullanıcı Adı"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/profile_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="email@email.com"
                android:textSize="14sp"
                android:textColor="#777777"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 💰 BAKİYE KART -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/balanceCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/profileCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toplam Bakiye"
                android:textSize="14sp"
                android:textColor="#777777"/>

            <TextView
                android:id="@+id/balance_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00 ₺"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/deposit_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Para Yatır"
                    android:backgroundTint="#2E7D32"
                    app:cornerRadius="14dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/withdraw_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Para Çek"
                    android:backgroundTint="#C62828"
                    app:cornerRadius="14dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ⚙ MENÜ KART -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/menuCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/balanceCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/menu_portfoy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Portföy"
                android:padding="18dp"
                android:textSize="16sp"
                android:drawablePadding="12dp"
                app:drawableStartCompat="@android:drawable/ic_menu_gallery"
                android:background="?attr/selectableItemBackground"
                />

            <TextView
                android:id="@+id/menu_islem_gecmisi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="İşlem Geçmişi"
                android:padding="18dp"
                android:textSize="16sp"
                android:drawablePadding="12dp"
                app:drawableStartCompat="@android:drawable/ic_menu_recent_history"
                android:background="?attr/selectableItemBackground"
                />

            <TextView
                android:id="@+id/menu_sifre_degistir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Şifre Değiştir"
                android:padding="18dp"
                android:textSize="16sp"
                android:drawablePadding="12dp"
                android:background="?attr/selectableItemBackground"
                android:drawableStart="@drawable/ic_lock"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 🚪 ÇIKIŞ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/logout_button"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="20dp"
        android:text="Çıkış Yap"
        android:backgroundTint="#C62828"
        app:cornerRadius="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>