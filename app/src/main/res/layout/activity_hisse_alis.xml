<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAlis"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#1E88E5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:navigationIcon="@drawable/baseline_arrow_back_24"
        app:title="Hisse Alış"
        app:titleTextColor="@android:color/white"/>

    <!-- Hisse Adı -->
    <TextView
        android:id="@+id/txtHisseAdi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarAlis"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Güncel Fiyat -->
    <TextView
        android:id="@+id/txtFiyat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fiyat: ₺245.30"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/txtHisseAdi"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"/>

    <!-- Lot Girişi -->
    <EditText
        android:id="@+id/edtLot"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Lot gir"
        android:inputType="number"
        android:maxLength="6"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtFiyat"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"/>

    <!-- Toplam Tutar -->
    <TextView
        android:id="@+id/txtToplam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Toplam: ₺0"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/edtLot"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"/>

    <!-- ALIŞ BUTONU -->
    <Button
        android:id="@+id/btnBuy"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="ALIŞ YAP"
        android:textSize="18sp"
        android:backgroundTint="#1E88E5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
